rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Videos: anyone can read; pipeline writes via Admin SDK (bypasses rules);
    // admins and mods can also write directly for manual curation
    match /videos/{videoId} {
      allow read: if true;
      allow write: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'mod'];

      // Discussion comments on spotlighted videos
      match /comments/{commentId} {
        allow read: if true;
        allow create: if request.auth != null;
        allow update, delete: if request.auth != null &&
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'mod'];
      }
    }

    // User profiles: own doc always; admins can read/write any profile
    match /users/{userId} {
      allow read, write: if request.auth != null && (
        request.auth.uid == userId ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
    }

    // Signal posts: anyone can read; admins and mods can write/delete
    match /signal_posts/{postId} {
      allow read: if true;
      allow write, delete: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'mod'];

      // Comments: anyone can read; authenticated users can create;
      // admins/mods can soft-delete (update) or hard-delete any comment
      match /comments/{commentId} {
        allow read: if true;
        allow create: if request.auth != null;
        allow update, delete: if request.auth != null &&
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'mod'];
      }
    }

    // Channel roster: anyone can read; admins and mods can write
    match /channels/{channelId} {
      allow read: if true;
      allow write: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'mod'];
    }

    // Pipeline settings: admins and mods can read; only admins can write
    match /settings/{doc} {
      allow read: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'mod'];
      allow write: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
